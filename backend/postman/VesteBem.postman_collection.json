{
  "info": {
    "name": "VesteBem API (v1)",
    "description": "Coleção de testes para o back-end VesteBem v1 (auth + doações + catálogo).\n\nAntes de usar:\n1. Crie um environment com a variável `baseUrl = http://localhost:3000`.\n2. Suba o servidor: `cd backend && npm run dev`.\n3. Comece pelo `Auth > Register`, depois `Auth > Login` (esse último salva `idToken` automaticamente).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "idToken", "value": "", "type": "string" },
    { "key": "doacaoId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"doador1@vestebem.dev\",\n  \"senha\": \"SenhaForte!1\",\n  \"nome\": \"Maria Doadora\",\n  \"telefone\": \"85999999999\",\n  \"endereco\": { \"cidade\": \"Fortaleza\", \"uf\": \"CE\" },\n  \"perfil\": \"doador\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('idToken', data.idToken);",
                  "  console.log('idToken salvo na collection variable');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"doador1@vestebem.dev\",\n  \"senha\": \"SenhaForte!1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{idToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            }
          }
        },
        {
          "name": "POST /auth/recover-password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"doador1@vestebem.dev\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/recover-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "recover-password"]
            }
          }
        }
      ]
    },
    {
      "name": "Doacoes",
      "item": [
        {
          "name": "POST /doacoes",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('doacaoId', data.id);",
                  "  console.log('doacaoId salvo:', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{idToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipoPeca\": \"Camisa\",\n  \"tamanho\": \"M\",\n  \"conservacao\": \"Seminova\",\n  \"descricao\": \"Camisa de algodao azul\",\n  \"fotoUrl\": \"https://exemplo.com/camisa.jpg\",\n  \"cidade\": \"Fortaleza\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/doacoes",
              "host": ["{{baseUrl}}"],
              "path": ["doacoes"]
            }
          }
        },
        {
          "name": "GET /doacoes/me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{idToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/doacoes/me",
              "host": ["{{baseUrl}}"],
              "path": ["doacoes", "me"]
            }
          }
        },
        {
          "name": "PUT /doacoes/:id",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{idToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tamanho\": \"G\",\n  \"conservacao\": \"Nova\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/doacoes/{{doacaoId}}",
              "host": ["{{baseUrl}}"],
              "path": ["doacoes", "{{doacaoId}}"]
            }
          }
        },
        {
          "name": "PATCH /doacoes/:id/entregar",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{idToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/doacoes/{{doacaoId}}/entregar",
              "host": ["{{baseUrl}}"],
              "path": ["doacoes", "{{doacaoId}}", "entregar"]
            }
          }
        },
        {
          "name": "PATCH /doacoes/:id/cancelar",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{idToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/doacoes/{{doacaoId}}/cancelar",
              "host": ["{{baseUrl}}"],
              "path": ["doacoes", "{{doacaoId}}", "cancelar"]
            }
          }
        }
      ]
    },
    {
      "name": "Catalogo",
      "item": [
        {
          "name": "GET /catalogo (todos)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/catalogo",
              "host": ["{{baseUrl}}"],
              "path": ["catalogo"]
            }
          }
        },
        {
          "name": "GET /catalogo (com filtros)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/catalogo?tipo=Camisa&tamanho=M&cidade=Fortaleza",
              "host": ["{{baseUrl}}"],
              "path": ["catalogo"],
              "query": [
                { "key": "tipo", "value": "Camisa" },
                { "key": "tamanho", "value": "M" },
                { "key": "cidade", "value": "Fortaleza" }
              ]
            }
          }
        }
      ]
    }
  ]
}
