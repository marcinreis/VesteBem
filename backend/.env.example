PORT=3000

# Origens permitidas pelo CORS, separadas por virgula.
# Em dev: front Vite roda em http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Firebase Admin SDK (Service Account)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Firebase Web API Key (Project Settings -> General -> Your apps)
# Necessaria para login email/senha via REST API do Firebase Auth
FIREBASE_WEB_API_KEY=
